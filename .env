# Application
APP_NAME=Chili Labs Backend API
APP_VERSION=1.0.0
DEBUG=True

# Database - SQLite (no setup needed!)
DATABASE_URL=sqlite:///./chililabs.db

# JWT Authentication
SECRET_KEY=super-secret-key-change-this-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload
UPLOAD_DIR=uploads/avatars
MAX_FILE_SIZE=5242880

# CORS (use * for all, or comma-separated: http://localhost:3000,http://localhost:8080)
CORS_ORIGINS=*